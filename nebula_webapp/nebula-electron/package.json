{
  "name": "nebula-electron",
  "private": true,
  "version": "1.1.0",
  "description": "Nebula Interview AI Assistant",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "build": "vite build",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run build && electron-builder --win",
    "package": "npm run build && electron-packager . --platform=win32 --arch=x64 --out=dist_electron --overwrite --icon=public/logo.ico --extra-resource=resources/engine_sidecar.exe --ignore=\"^/(src|node_modules|build|dist_electron|.git|.venv|tsconfig.*|vite.config.ts|eslint.config.js|.gitignore|README.md)\" --prune=true"
  },
  "dependencies": {
    "framer-motion": "^12.34.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^31.7.7",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "lucide-react": "^0.575.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.nebula.assistant",
    "productName": "Nebula Interview AI",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "public/**/*",
      "resources/engine_sidecar.exe"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/logo.png",
      "signingHashAlgorithms": []
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Nebula Assistant",
      "installerIcon": "public/logo.png",
      "uninstallerIcon": "public/logo.png",
      "installerHeaderIcon": "public/logo.png"
    }
  }
}